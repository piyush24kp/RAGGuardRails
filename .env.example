# Copy this file to .env and fill in your keys. Never commit .env to git.

# Groq (free LLM) — get at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# LangSmith (monitoring) — copy from https://smith.langchain.com/ → Settings → API Keys
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://aws.api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="rag-rbac-chatbot"

# ChromaDB persistence path
CHROMA_PERSIST_DIR=./chroma_db
